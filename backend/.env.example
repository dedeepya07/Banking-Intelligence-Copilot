# Database Configuration
DATABASE_URL=sqlite:///./banking_intelligence.db
# For PostgreSQL use: postgresql://user:password@localhost:5432/dbname

# JWT Configuration
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# LLM Configuration
# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
USE_OPENAI=false

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_ENABLED=false

# Phase 2 Configuration (for future use)
MAPS_API_KEY=your-maps-api-key
VOICE_API_ENABLED=false

# Application Configuration
APP_NAME=Banking Intelligence Copilot
VERSION=1.0.0
DEBUG=false

# Security Configuration
MAX_QUERY_RESULTS=1000
QUERY_TIMEOUT_SECONDS=30

# Instructions:
# 1. Copy this file to .env
# 2. Fill in your actual API keys and configuration
# 3. Set USE_OPENAI=true if you want to use OpenAI
# 4. Set OLLAMA_ENABLED=true if you want to use Ollama
# 5. Never commit .env file to version control
# 6. Keep your API keys secure and private
